generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
  INVESTOR
}

enum DocumentStatus {
  PENDING
  SIGNED
  REJECTED
  EXPIRED
}

enum CompanyType {
  INVESTOR
  BROKER
  ADVISOR
  TENANT
  OTHER
}

enum StageStatusValue {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
  DECLINED
}

enum LifecycleStatus {
  ACTIVE
  COMPLETED
  DROPPED
  ON_HOLD
}

enum InterestLevel {
  HOT
  WARM
  COLD
  NONE
}

enum ContentType {
  PDF
  LANDING_PAGE
}

// ─── 1. User ────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  isActive     Boolean  @default(true)
  companyId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company            Company?              @relation(fields: [companyId], references: [id])
  createdAssets      Asset[]               @relation("AssetCreator")
  ownedRows          AssetCompanyTracking[] @relation("TrackingOwner")
  comments           Comment[]
  stageUpdates       StageStatus[]         @relation("StageUpdater")
  stageApprovals     StageStatus[]         @relation("StageApprover")
  stageHistory       StageHistory[]
  activityLogs       ActivityLog[]
  savedViews         SavedView[]
  uploadedDocuments  Document[]            @relation("DocumentUploader")
  createdInvites     InvestorInvite[]      @relation("InviteCreator")
}

// ─── 2. Asset ───────────────────────────────────────────────────────────────
model Asset {
  id              String   @id @default(cuid())
  title           String
  address         String
  city            String
  country         String
  brokerLabel     String?
  assetType       String?
  transactionType String?
  ownerEntity     String?
  description     String?
  // Admin-supplied defaults for document placeholders, keyed by UPPERCASE
  // token name (e.g. { "BUILDING_NAME": "Keizersgracht 250", "VENDOR": "Dils" }).
  // When a document is signed, these override any matching values the
  // investor might have typed — they are the source of truth for
  // project-level info such as building name, vendor, address.
  fieldDefaults   Json?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy  User                   @relation("AssetCreator", fields: [createdById], references: [id])
  trackings  AssetCompanyTracking[]
  savedViews SavedView[]
  invites    InvestorInvite[]
  contents   AssetContent[]
}

// ─── 3. Company ─────────────────────────────────────────────────────────────
model Company {
  id           String      @id @default(cuid())
  name         String
  legalName    String?
  type         CompanyType @default(INVESTOR)
  website      String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  notes        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  trackings AssetCompanyTracking[]
  users     User[]
  invites   InvestorInvite[]
}

// ─── 4. PipelineStage ───────────────────────────────────────────────────────
model PipelineStage {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  sequence  Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stageStatuses StageStatus[]
  stageHistory  StageHistory[]
  documents     Document[]
}

// ─── 5. AssetCompanyTracking ────────────────────────────────────────────────
model AssetCompanyTracking {
  id                       String          @id @default(cuid())
  assetId                  String
  companyId                String
  relationshipType         String          @default("Investor")
  currentStageKey          String?
  currentStageManualOverride Boolean       @default(false)
  lifecycleStatus          LifecycleStatus @default(ACTIVE)
  interestLevel            InterestLevel?
  ownerUserId              String?
  priority                 Int?
  latestCommentPreview     String?
  sortOrder                Int?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ownerUser    User?         @relation("TrackingOwner", fields: [ownerUserId], references: [id])
  stageStatuses StageStatus[]
  comments     Comment[]
  stageHistory StageHistory[]
  documents    Document[]

  @@unique([assetId, companyId])
}

// ─── 6. StageStatus ─────────────────────────────────────────────────────────
model StageStatus {
  id               String           @id @default(cuid())
  trackingId       String
  stageId          String
  status           StageStatusValue @default(NOT_STARTED)
  completedAt      DateTime?
  dueDate          DateTime?
  updatedByUserId  String?
  approvedAt       DateTime?
  approvedByUserId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tracking   AssetCompanyTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  stage      PipelineStage        @relation(fields: [stageId], references: [id], onDelete: Cascade)
  updatedBy  User?                @relation("StageUpdater", fields: [updatedByUserId], references: [id])
  approvedBy User?                @relation("StageApprover", fields: [approvedByUserId], references: [id])

  @@unique([trackingId, stageId])
  @@index([stageId])
}

// ─── 7. Comment ─────────────────────────────────────────────────────────────
model Comment {
  id           String   @id @default(cuid())
  trackingId   String
  authorUserId String
  body         String
  isPinned     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tracking AssetCompanyTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  author   User                 @relation(fields: [authorUserId], references: [id])

  @@index([trackingId])
}

// ─── 8. StageHistory ────────────────────────────────────────────────────────
model StageHistory {
  id              String   @id @default(cuid())
  trackingId      String
  stageId         String?
  fieldName       String
  oldValue        String?
  newValue        String?
  changedByUserId String
  note            String?
  createdAt       DateTime @default(now())

  tracking  AssetCompanyTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  stage     PipelineStage?       @relation(fields: [stageId], references: [id])
  changedBy User                 @relation(fields: [changedByUserId], references: [id])

  @@index([trackingId])
  @@index([createdAt])
}

// ─── 9. ActivityLog ─────────────────────────────────────────────────────────
model ActivityLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  metadata   Json?
  userId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── 10. SavedView ──────────────────────────────────────────────────────────
model SavedView {
  id           String   @id @default(cuid())
  userId       String
  assetId      String?
  name         String
  filterConfig Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  asset Asset? @relation(fields: [assetId], references: [id])
}

// ─── 11. Document ───────────────────────────────────────────────────────────
model Document {
  id               String         @id @default(cuid())
  trackingId       String
  stageId          String
  fileName         String
  fileUrl          String
  fileSize         Int
  mimeType         String         @default("application/pdf")
  uploadedByUserId String
  status           DocumentStatus @default(PENDING)
  signedAt         DateTime?
  signedByName     String?
  signedByEmail    String?
  signatureData    String?
  signedFileUrl    String?
  fieldConfig      Json?
  placeholderMap   Json?     // Detected placeholders: { "SIGNATURE": {page, x, y, width, height, fontSize}, ... }
  placementMode    String    @default("GRID")  // "GRID" | "PLACEHOLDER" | "MANUAL"
  rejectedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tracking      AssetCompanyTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  stage         PipelineStage        @relation(fields: [stageId], references: [id])
  uploadedBy    User                 @relation("DocumentUploader", fields: [uploadedByUserId], references: [id])
  signingTokens SigningToken[]

  @@index([trackingId])
  @@index([stageId])
}

// ─── 12. SigningToken ───────────────────────────────────────────────────────
model SigningToken {
  id         String    @id @default(cuid())
  documentId String
  token      String    @unique @default(cuid())
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// ─── 13. InvestorInvite ─────────────────────────────────────────────────────
model InvestorInvite {
  id          String    @id @default(cuid())
  companyId   String
  assetId     String
  email       String
  token       String    @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  company   Company @relation(fields: [companyId], references: [id])
  asset     Asset   @relation(fields: [assetId], references: [id])
  createdBy User    @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([email, acceptedAt])
  @@index([companyId])
}

// ─── 14. AssetContent ───────────────────────────────────────────────────────
model AssetContent {
  id             String      @id @default(cuid())
  assetId        String
  stageKey       String
  contentType    ContentType
  title          String
  fileUrl        String?
  fileName       String?
  htmlContent    String?
  description    String?
  imageUrls      Json?
  keyMetrics     Json?
  isPublished    Boolean     @default(false)
  // Detected {{TOKEN}} / {TOKEN} placeholders for PDF content (master NDA, IM)
  // Shape: Record<string, { page, x, y, width, height, fontSize }>
  placeholderMap Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, stageKey])
  @@index([assetId, isPublished])
}
