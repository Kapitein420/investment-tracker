# ────────────────────────────────────────────────────────────────
# Template only — copy to `.env` and fill in real values locally.
# NEVER put real values in this file — it's committed to git.
# Production values live in Vercel → Settings → Environment Variables.
# ────────────────────────────────────────────────────────────────

# Postgres (Supabase connection pooler or direct URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/investment_tracker"

# NextAuth — generate the secret with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Supabase — dashboard → Project Settings → API
# The URL leaks to the browser via NEXT_PUBLIC_ — that's fine, URLs aren't secrets.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# Service role key: full admin access, server-side ONLY, never ships to browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Mailgun — dashboard → API Keys → "Sending API key". Used by src/lib/email.ts
# for investor invites, NDA approvals, password resets, etc. Production key goes
# ONLY in Vercel env vars, never in this file.
MAILGUN_API_KEY=""
# Sending domain configured in Mailgun (e.g. mg.dils.com).
MAILGUN_DOMAIN="mg.dils.com"
# Default From header. Mailgun accepts "Display Name <email@domain>".
MAILGUN_FROM="Investment Tracker <investments.netherlands@mg.dils.com>"
# Mailgun region base URL.
#   EU (default): https://api.eu.mailgun.net/v3
#   US:           https://api.mailgun.net/v3
MAILGUN_API_BASE="https://api.eu.mailgun.net/v3"
# Optional override for the email logo URL. The template defaults to
# `${getAppUrl()}/email/dils-logo.png` (file shipped at public/email/dils-logo.png).
# Only set this if you want to host the logo on a CDN or external URL.
EMAIL_LOGO_URL=""

# Health endpoint secret — required in production, else /api/health returns 503.
# Generate with: openssl rand -hex 24
HEALTH_SECRET=""
